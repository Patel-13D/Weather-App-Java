<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#000000">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/_20sdp"
            android:layout_marginEnd="@dimen/_16sdp">
            <ImageView
                android:id="@+id/widget"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="@dimen/_40sdp"
                android:src="@drawable/widget"
                app:tint="@color/black" />

            <ImageView
                android:id="@+id/add"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/_40sdp"
                android:src="@drawable/plus"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/setting"
                android:layout_width="@dimen/_22sdp"
                android:layout_height="@dimen/_22sdp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:src="@drawable/setting"
                app:tint="@color/white" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_20sdp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_10sdp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/map"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_25sdp"
                android:layout_gravity="center"
                android:src="@drawable/map"
                app:tint="@color/white"/>
            <TextView
                android:id="@+id/tvCityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:fontFamily="@font/inter_bold"
                android:text="Locating..."
                android:textColor="@android:color/white"
                android:textSize="@dimen/_27ssp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_marginStart="@dimen/_15sdp"
            android:fontFamily="@font/inter_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday- 10 May"
            android:textColor="@android:color/white"
            android:alpha="0.7"
            android:textSize="@dimen/_25ssp" />

        <TextView
            android:id="@+id/tvTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="19°"
            android:textColor="@android:color/white"
            android:textSize="190sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_8sdp"
            android:weightSum="1">
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"
                android:fontFamily="@font/inter_bold"
                android:text="Clear Sky"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvMaxMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:fontFamily="@font/inter_bold"
                android:gravity="end"
                android:text="19° / 12°"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp"
            android:weightSum="1"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvWind"
                android:layout_weight="0.5"
                android:layout_width="0dp"
                android:textSize="@dimen/_13ssp"
                android:layout_height="wrap_content"
                android:text="Wind: -- km/h"
                android:fontFamily="@font/inter_bold"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvHumidity"
                android:layout_weight="0.5"
                android:layout_width="0dp"
                android:textSize="@dimen/_13ssp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="Humidity: --%"
                android:fontFamily="@font/inter_bold"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/_20sdp"
                android:paddingStart="@dimen/_5sdp"
                android:paddingEnd="@dimen/_10sdp"
                android:paddingTop="@dimen/_400sdp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="@dimen/_25sdp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_10sdp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingBottom="@dimen/_1sdp">
                            <ImageView
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:src="@drawable/schedule" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quicksand_light"
                                android:text="5-Day Forecast"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_18ssp" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvDailyForecast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMoreForecast"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_60sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:fontFamily="@font/inter_bold"
                            android:text="5-Day Forecast"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="#4DFFFFFF"
                            app:cornerRadius="@dimen/_15sdp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:layout_marginBottom="@dimen/_10sdp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="@dimen/_25sdp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/_16sdp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="@dimen/_10sdp">
                            <ImageView
                                android:layout_width="@dimen/_23sdp"
                                android:layout_height="@dimen/_23sdp"
                                android:layout_marginEnd="@dimen/_10sdp"
                                android:src="@drawable/clock" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24-Hour Forecast"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_18ssp"
                                android:fontFamily="@font/quicksand_light" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvHourlyForecast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="@dimen/_8sdp"
                            android:clipToPadding="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:padding="@dimen/_4sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPressure"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:strokeWidth="0dp"
                        app:strokeColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/_20sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pressure"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/txtPre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_60sdp"
                                android:layout_height="@dimen/_60sdp"
                                android:src="@drawable/windp"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardHumidity"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:strokeWidth="0dp"
                        app:strokeColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/_25sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Humidity"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/txtHumPer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_50sdp"
                                android:layout_height="@dimen/_50sdp"
                                android:src="@drawable/humidity"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:padding="@dimen/_4sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="@dimen/_20sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Real Feel"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/txtFeel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_60sdp"
                                android:layout_height="@dimen/_60sdp"
                                android:src="@drawable/realfeel"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVisibility"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        android:layout_marginStart="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:cardCornerRadius="@dimen/_25sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Visibility"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/tvVisibilityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_50sdp"
                                android:layout_height="@dimen/_50sdp"
                                android:src="@drawable/visibility"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:padding="@dimen/_4sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="@dimen/_20sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sunset"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/sunset"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_60sdp"
                                android:layout_height="@dimen/_60sdp"
                                android:src="@drawable/sunset"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_170sdp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="@dimen/_5sdp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:cardCornerRadius="@dimen/_25sdp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/_20sdp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sunrise"
                                android:textColor="#B3FFFFFF"
                                android:textSize="@dimen/_15ssp" />
                            <TextView
                                android:id="@+id/sunrise"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_20ssp"
                                android:layout_marginTop="@dimen/_8sdp" />
                            <ImageView
                                android:layout_width="@dimen/_50sdp"
                                android:layout_height="@dimen/_50sdp"
                                android:src="@drawable/sunrise"
                                android:layout_gravity="end"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>